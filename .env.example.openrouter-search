# OpenRouter semantic search
# Required for /api/albums/[albumSlug]/search to rank results by pgvector similarity.
OPENROUTER_API_KEY=

# Must match PHOTO_IMAGE_EMBED_MODEL_ID in the image-indexing worker.
OPENROUTER_EMBEDDING_MODEL=google/gemini-embedding-2
OPENROUTER_APP_TITLE=Saathidesk AI Photo Search
OPENROUTER_HTTP_REFERER=https://www.saathidesk.com
