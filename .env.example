RESEND_API_KEY=re_your_api_key
# Optional after verifying your own sending domain:
RESEND_FROM_EMAIL="SaathiDesk <contact@your-verified-domain.com>"

# Required for post-upload video playback normalization with AWS Elemental MediaConvert.
MEDIACONVERT_ROLE_ARN=arn:aws:iam::<account-id>:role/MediaConvertHlsVideoRole
# Optional. Defaults to the account's MediaConvert default queue in AWS_REGION.
MEDIACONVERT_QUEUE_ARN=arn:aws:mediaconvert:<region>:<account-id>:queues/Default
