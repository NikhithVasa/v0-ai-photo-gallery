RESEND_API_KEY=re_your_api_key
# Optional after verifying your own sending domain:
RESEND_FROM_EMAIL="SaathiDesk <contact@your-verified-domain.com>"

# CloudFront image delivery (optional)
NEXT_PUBLIC_ENABLE_CLOUDFRONT_IMAGES=false
NEXT_PUBLIC_CLOUDFRONT_IMAGE_BASE_URL=
NEXT_PUBLIC_FORCE_CLOUDFRONT_IMAGES=false

# CloudFront video streaming (optional, HLS)
NEXT_PUBLIC_ENABLE_CLOUDFRONT_VIDEOS=false
NEXT_PUBLIC_CLOUDFRONT_VIDEO_BASE_URL=
