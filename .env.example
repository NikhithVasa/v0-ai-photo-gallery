RESEND_API_KEY=re_your_api_key
# Optional after verifying your own sending domain:
RESEND_FROM_EMAIL="SaathiDesk <contact@your-verified-domain.com>"
# Optional. Add newsletter subscribers to this Resend segment.
RESEND_NEWSLETTER_SEGMENT_ID=

# Optional. Set to true to render the composable Radix-style gallery lightbox.
NEXT_PUBLIC_COMPOSABLE_LIGHTBOX=false

# Optional. Enables the feature-rich public landing page experience.
NEXT_PUBLIC_FEATURE_RICH_LANDING=false
# Optional. Applies the vivid color system to the feature-rich landing page only.
NEXT_PUBLIC_FEATURE_VIBRANT_LANDING=false

# Required for post-upload video playback normalization with AWS Elemental MediaConvert.
MEDIACONVERT_ROLE_ARN=arn:aws:iam::<account-id>:role/MediaConvertHlsVideoRole
# Optional. Defaults to the account's MediaConvert default queue in AWS_REGION.
MEDIACONVERT_QUEUE_ARN=arn:aws:mediaconvert:<region>:<account-id>:queues/Default
